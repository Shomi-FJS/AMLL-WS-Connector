{
	"name": "amll-ws-connector",
	"version": "0.1.2",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "bun scripts/build.ts",
		"dev": "bun scripts/build.ts --dev --watch",
		"typecheck": "bun tsgo -b",
		"lint": "bun biome check .",
		"format": "bun biome format . --write",
		"devtools:launch": "bun scripts/launch-cloudmusic-devtools.ts",
		"devtools:resolve": "bun scripts/devtools-resolve.ts",
		"devtools:proxy": "bun scripts/devtools-proxy.ts",
		"devtools:tail": "bun scripts/devtools-tail.ts",
		"cs:add": "bun changeset add",
		"cs:version": "bun changeset version && bun scripts/sync-versions.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@changesets/cli": "^2.30.0",
		"@types/bun": "^1.3.11",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260401.1",
		"chrome-remote-interface": "^0.34.0",
		"redux": "^5.0.1"
	},
	"dependencies": {
		"@emotion/cache": "^11.14.0",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^7.3.9",
		"@mui/material": "^7.3.9",
		"jotai": "^2.19.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"ttml-processor": "^0.1.4",
		"uuid": "^13.0.0",
		"ws": "^8.20.0"
	},
	"packageManager": "bun@1.3.11"
}
